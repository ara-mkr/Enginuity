# ENGINGUITY environment configuration
# Copy to .env and adjust as needed. Both variables are optional.
#
# API keys (OpenRouter / Anthropic) are NOT configured here — enter them
# in-app (Settings → Connect AI); they are kept in sessionStorage only.
# The Ollama host is also configured in-app (AI Settings → Local).

# Collaboration WebSocket server (see README § Collaboration).
# Full URL takes precedence; use wss:// behind TLS in production.
VITE_COLLAB_WS_URL=ws://localhost:3001

# Or keep the same-origin default and just override its port:
# VITE_COLLAB_WS_PORT=3001

# Velxio circuit simulator integration.
# In local Vite dev, Enginguity defaults to http://localhost:3080 when this is
# unset. Set it explicitly for production, Electron builds, or reverse proxies.
VITE_VELXIO_URL=http://localhost:3080

# Hosted fallback is opt-in so Enginguity does not silently depend on velxio.dev.
VITE_VELXIO_ALLOW_HOSTED_FALLBACK=false
VITE_VELXIO_HOSTED_URL=https://velxio.dev

# Dev-only embeddable proxy for the hosted Velxio (scripts/velxioProxyPlugin.ts).
# When the Docker service is not running, `npm run dev` serves the hosted
# simulator through http://127.0.0.1:3081 with frame-blocking headers stripped,
# so the Circuit Simulator tab works without Docker. The UI badge shows
# "Hosted (dev proxy)" whenever this source is in use. Never part of builds.
VITE_VELXIO_DEV_PROXY=true
VITE_VELXIO_DEV_PROXY_PORT=3081

# Keep iframe mode unless the app adds a reviewed proxy/webview integration.
VITE_VELXIO_EMBED_MODE=iframe
VITE_VELXIO_HEALTHCHECK_PATH=/
VITE_VELXIO_ENABLE_NEW_TAB_FALLBACK=true

# Default sandbox is intentionally scoped for Velxio's browser simulator:
# scripts/own origin storage, forms, downloads, popups, modals, and pointer lock.
# VITE_VELXIO_IFRAME_SANDBOX="allow-scripts allow-same-origin allow-forms allow-downloads allow-popups allow-modals allow-pointer-lock"
# VITE_VELXIO_IFRAME_ALLOW="clipboard-read; clipboard-write; fullscreen"
