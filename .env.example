# ENGINGUITY environment configuration
# Copy to .env and adjust as needed. Both variables are optional.
#
# API keys (OpenRouter / Anthropic) are NOT configured here — enter them
# in-app (Settings → Connect AI); they are kept in sessionStorage only.
# The Ollama host is also configured in-app (AI Settings → Local).

# Collaboration WebSocket server (see README § Collaboration).
# Full URL takes precedence; use wss:// behind TLS in production.
VITE_COLLAB_WS_URL=ws://localhost:3001

# Or keep the same-origin default and just override its port:
# VITE_COLLAB_WS_PORT=3001
