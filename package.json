{
  "name": "enginguity",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -k -n VELXIO,APP -c blue,green \"docker compose -f docker-compose.velxio.yml up\" \"vite\"",
    "dev:all:down": "docker compose -f docker-compose.velxio.yml down",
    "build": "tsc -b && vite build",
    "type-check": "tsc -b",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "collab": "node collaboration-server.js",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "tsc -b && cross-env ELECTRON_BUILD=true vite build && electron-builder",
    "electron:build:mac": "tsc -b && cross-env ELECTRON_BUILD=true vite build && electron-builder --mac",
    "electron:build:win": "tsc -b && cross-env ELECTRON_BUILD=true vite build && electron-builder --win",
    "electron:build:linux": "tsc -b && cross-env ELECTRON_BUILD=true vite build && electron-builder --linux",
    "electron:build:all": "tsc -b && cross-env ELECTRON_BUILD=true vite build && electron-builder --mac --win"
  },
  "dependencies": {
    "@types/three": "^0.184.1",
    "dxf-parser": "^1.1.2",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^1.17.0",
    "papaparse": "^5.5.3",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "three": "^0.184.0",
    "uuid": "^14.0.0",
    "ws": "^8.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.3",
    "cross-env": "^10.1.0",
    "electron": "^34.5.8",
    "electron-builder": "^26.15.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.9",
    "wait-on": "^9.0.10"
  }
}
